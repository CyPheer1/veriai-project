COMPOSE_PROJECT_NAME=veriai
APP_ENV=docker

FRONTEND_PORT=3000
BACKEND_PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

POSTGRES_DB=veriai
POSTGRES_USER=veriai_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/veriai
SPRING_DATASOURCE_USERNAME=veriai_user
SPRING_DATASOURCE_PASSWORD=change-me-postgres-password
SPRING_JPA_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_ACTUATOR_EXPOSURE=health,info,prometheus

JWT_SECRET=change-me-super-long-random-jwt-secret
JWT_EXPIRATION_SECONDS=86400
FREE_PLAN_DAILY_LIMIT=3
AI_SERVICE_BASE_URL=http://ai-service:8000
AI_SERVICE_ENQUEUE_PATH=/internal/v1/analyze
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

HUGGINGFACE_MODEL_NAME=mehddii/roberta-aigt-finetuning-v4
GPT2_MODEL_NAME=gpt2-medium
HF_HOME=/models-cache
LOAD_MODELS_ON_STARTUP=true
CHUNK_MIN_WORDS=120
CHUNK_MAX_WORDS=512
CHUNK_MIN_PROCESS_WORDS=50
RELIABILITY_MIN_WORDS=120
FULL_MODE_LAYER1_WEIGHT=0.6
FULL_MODE_LAYER2_WEIGHT=0.2
FULL_MODE_LAYER3_WEIGHT=0.2
AI_LABEL_THRESHOLD=0.5
DEFAULT_CONFIDENCE=0.5
CELERY_TASK_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_BASE=2
CELERY_WATCHDOG_SCHEDULE_SECONDS=600
CELERY_WATCHDOG_STUCK_MINUTES=30

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
