project_id = "your-gcp-project-id"
region = "europe-west3"
frontend_region = "europe-west1"

service_name_prefix = "veriai"

frontend_image = "europe-west3-docker.pkg.dev/your-gcp-project-id/veriai-images/frontend:latest"
backend_image = "europe-west3-docker.pkg.dev/your-gcp-project-id/veriai-images/backend-java:latest"
ai_service_image = "europe-west3-docker.pkg.dev/your-gcp-project-id/veriai-images/ai-service:latest"
detection_worker_image = "europe-west3-docker.pkg.dev/your-gcp-project-id/veriai-images/detection-worker:latest"
detection_beat_image = "europe-west3-docker.pkg.dev/your-gcp-project-id/veriai-images/detection-beat:latest"

# For the final frontend cutover after replacing the placeholder backend URL,
# prefer a unique frontend tag such as:
# frontend_image = "europe-west3-docker.pkg.dev/your-gcp-project-id/veriai-images/frontend:fix20260502-120000"

frontend_url = "https://your-frontend-url"
backend_cors_allowed_origins = "https://your-frontend-url"

database_url = "postgresql+psycopg2://user:password@your-neon-host:5432/veriai"
spring_datasource_url = "jdbc:postgresql://your-neon-host:5432/veriai?sslmode=require"
spring_datasource_username = "your-db-user"
spring_datasource_password = "your-db-password"

redis_tier = "BASIC"
redis_memory_gb = 1

internal_service_token = "change-me-internal-service-token"
jwt_secret = "change-me-super-long-random-jwt-secret"
grafana_admin_password = "change-me-grafana-password"
